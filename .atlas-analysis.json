  "keyFeatures": [
    "Real-time terminal telemetry dashboard with map and fleet status",
    "Transaction monitoring with filtering, search, and export",
    "Customer (merchant) management with outlets and operators",
    "POS terminal inventory management and device parameterization",
    "Role-based access control with fine-grained permissions",
    "Maker-checker approval workflow for sensitive operations",
    "Audit trail and compliance reporting",
    "Support request ticketing via Lango Mobile",
    "Multi-currency support",
    "Bulk user upload and management"
  ],
